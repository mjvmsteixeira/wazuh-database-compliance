{
  "_comment": "ISM policy applied directly via OpenSearch API (PUT _plugins/_ism/policies/wazuh-db-audit-retention)",
  "policy": {
    "description": "Retention for DB audit logs — PCI-DSS 10.7",
    "default_state": "hot",
    "states": [
      {"name": "hot", "actions": [{"rollover": {"min_size": "50gb", "min_index_age": "30d"}}], "transitions": [{"state_name": "warm", "conditions": {"min_index_age": "30d"}}]},
      {"name": "warm", "actions": [{"force_merge": {"max_num_segments": 1}}], "transitions": [{"state_name": "cold", "conditions": {"min_index_age": "180d"}}]},
      {"name": "cold", "actions": [], "transitions": [{"state_name": "delete", "conditions": {"min_index_age": "365d"}}]},
      {"name": "delete", "actions": [{"delete": {}}], "transitions": []}
    ],
    "ism_template": [{"index_patterns": ["wazuh-alerts-*"], "priority": 100}]
  }
}
